# @worlds/client provider
# No external API keys required — uses file-backed LibSQL for local eval runs.

# Judge / answering model (required for full pipeline)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Also supported by the Google AI SDK:
# GOOGLE_GENERATIVE_AI_API_KEY=

